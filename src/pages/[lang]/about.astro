const c = content[lang];
const leadershipPhotos = [photoFounder, photoEsther, photoJustus];

/* Pillar colour mapping */
const pillarColors = [
  { bg: 'bg-green-50', border: 'border-green', text: 'text-green', iconBg: 'bg-green-100' },
  { bg: 'bg-gold-50', border: 'border-gold', text: 'text-gold-dark', iconBg: 'bg-gold-100' },
  { bg: 'bg-dynared-50', border: 'border-dynared', text: 'text-dynared', iconBg: 'bg-dynared-100' },
];

/* Timeline dot colours */
const timelineColors = ['bg-green', 'bg-gold', 'bg-dynared', 'bg-green', 'bg-gold', 'bg-dynared'];
---

<BaseLayout title={c.meta.title} description={c.meta.description} lang={lang}>

  <!-- ═══════════════════════════════════════════
       HERO — About page hero
       ═══════════════════════════════════════════ -->
  <section class="relative min-h-[50vh] md:min-h-[60vh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={heroAbout}
        alt={c.hero.heroAlt}
        class="w-full h-full object-cover"
        widths={[640, 1024, 1600]}
        sizes="100vw"
        loading="eager"
        quality={80}
      />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal/90 via-charcoal/75 to-charcoal/50"></div>
    </div>

    <div class="relative section-container py-20 md:py-28">
      <div class="max-w-2xl">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
          {c.hero.heading}
        </h1>
        <p class="mt-4 text-lg md:text-xl text-cream/85 font-body max-w-xl leading-relaxed">
          {c.hero.subtitle}
        </p>
      </div>
    </div>

    <!-- Diagonal bottom edge -->
    <div class="absolute bottom-0 left-0 right-0 h-16 md:h-24">
      <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0 100L1440 30V100H0Z" fill="var(--color-cream)" />
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       ORIGINS — The founding story
       ═══════════════════════════════════════════ -->
  <section class="section-padding bg-cream">
    <div class="section-container">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge bg-green-50 text-green mb-4">{c.origins.sectionTag}</span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-charcoal">
          {c.origins.heading}
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Text -->
        <div class="space-y-5">
          <p class="font-body text-charcoal-light leading-relaxed">{c.origins.p1}</p>
          <p class="font-body text-charcoal-light leading-relaxed">{c.origins.p2}</p>
          <p class="font-body text-charcoal-light leading-relaxed">{c.origins.p3}</p>
        </div>

        <!-- Photos -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={photoOiHoChooi}
              alt={c.origins.altOiHoChooi}
              class="w-full h-auto object-cover"
              widths={[300, 480]}
              sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 100vw"
              loading="lazy"
            />
          </div>
          <div class="rounded-2xl overflow-hidden shadow-lg sm:mt-8">
            <Image
              src={photoHeadquarters}
              alt={c.origins.altHQ}
              class="w-full h-auto object-cover"
              widths={[300, 480]}
              sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 100vw"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Diagonal divider -->
  <div class="relative h-16 md:h-24 bg-cream">
    <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="absolute bottom-0 w-full h-full" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 100L1440 0V100H0Z" fill="white" />
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════
       AFRICA CHAPTER — Esther Ampumuza story
       ═══════════════════════════════════════════ -->
  <section class="section-padding bg-white">
    <div class="section-container">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge bg-dynared-50 text-dynared mb-4">{c.africa.sectionTag}</span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-charcoal">
          {c.africa.heading}
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Photos first on desktop (order reversed) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:order-1">
          <div class="rounded-2xl overflow-hidden shadow-lg">
            <Image
              src={photoEsther}
              alt={c.africa.altEsther}
              class="w-full h-auto object-cover"
              widths={[300, 480]}
              sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 100vw"
              loading="lazy"
            />
          </div>
          <div class="rounded-2xl overflow-hidden shadow-lg sm:mt-8">
            <Image
              src={photoEstherOi}
              alt={c.africa.altEstherOi}
              class="w-full h-auto object-cover"
              widths={[300, 480]}
              sizes="(min-width: 1024px) 280px, (min-width: 640px) 45vw, 100vw"
              loading="lazy"
            />
          </div>
        </div>

        <!-- Text -->
        <div class="space-y-5 lg:order-2">
          <p class="font-body text-charcoal-light leading-relaxed">{c.africa.p1}</p>
          <p class="font-body text-charcoal-light leading-relaxed">{c.africa.p2}</p>
          <p class="font-body text-charcoal-light leading-relaxed">{c.africa.p3}</p>
          <p class="font-body text-charcoal-light leading-relaxed">{c.africa.p4}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MISSION, VISION & VALUES
       ═══════════════════════════════════════════ -->
  <section class="relative overflow-hidden">
    <!-- Diagonal top -->
    <div class="absolute top-0 left-0 right-0 h-16 md:h-24 z-10">
      <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0 0H1440V60L0 100V0Z" fill="white" />
      </svg>
    </div>

    <div class="bg-gradient-to-br from-charcoal via-charcoal to-dynared-900 py-28 md:py-36 grain-overlay">
      <div class="section-container relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-14">
          <span class="badge bg-gold/20 text-gold mb-4">{c.mission.sectionTag}</span>
          <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white">
            {c.mission.heading}
          </h2>
        </div>

        <!-- Mission & Vision cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
            <div class="w-12 h-12 rounded-xl bg-dynared/20 flex items-center justify-center mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-dynared-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">{c.mission.mission.title}</h3>
            <p class="text-cream/80 font-body leading-relaxed text-lg">{c.mission.mission.text}</p>
          </div>

          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
            <div class="w-12 h-12 rounded-xl bg-gold/20 flex items-center justify-center mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-gold-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="font-heading text-xl font-bold text-white mb-3">{c.mission.vision.title}</h3>
            <p class="text-cream/80 font-body leading-relaxed text-lg">{c.mission.vision.text}</p>
          </div>
        </div>

        <!-- Values -->
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 md:p-10 border border-white/10">
          <h3 class="font-heading text-xl font-bold text-white mb-6">{c.mission.values.title}</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {c.mission.values.items.map((value, i) => (
              <div class="flex gap-3">
                <div class="w-8 h-8 rounded-lg bg-green/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                  </svg>
                </div>
                <div>
                  <p class="font-heading text-sm font-bold text-white mb-1">{value.name}</p>
                  <p class="text-cream/70 font-body text-sm leading-relaxed">{value.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Diagonal bottom -->
    <div class="absolute bottom-0 left-0 right-0 h-16 md:h-24 z-10">
      <svg viewBox="0 0 1440 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0 40L1440 100V0H0V40Z" fill="var(--color-cream)" />
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       BRAND PILLARS — Health, Wealth, Freedom
       ═══════════════════════════════════════════ -->
  <section class="section-padding bg-cream">
    <div class="section-container">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge bg-gold-50 text-gold-dark mb-4">{c.pillars.sectionTag}</span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-charcoal">
          {c.pillars.heading}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {c.pillars.items.map((pillar, i) => (
          <div class={`rounded-2xl p-8 md:p-10 border-l-4 ${pillarColors[i].border} ${pillarColors[i].bg} transition-all duration-300 hover:shadow-lg`}>
            <div class={`w-14 h-14 rounded-2xl ${pillarColors[i].iconBg} ${pillarColors[i].text} flex items-center justify-center mb-6`}>
              {i === 0 && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>
              )}
              {i === 1 && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4 4L21.75 6M17.25 6h4.5v4.5" /></svg>
              )}
              {i === 2 && (
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg>
              )}
            </div>
            <h3 class={`font-heading text-2xl font-bold mb-3 ${pillarColors[i].text}`}>{pillar.title}</h3>
            <p class="text-charcoal-light font-body leading-relaxed">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MILESTONES TIMELINE
       ═══════════════════════════════════════════ -->
  <section class="section-padding bg-white">
    <div class="section-container">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge bg-dynared-50 text-dynared mb-4">{c.milestones.sectionTag}</span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-charcoal">
          {c.milestones.heading}
        </h2>
      </div>

      <!-- Timeline -->
      <div class="relative max-w-4xl mx-auto">
        <!-- Vertical line -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-0.5 bg-grey-light/50 -translate-x-1/2" aria-hidden="true"></div>

        {c.milestones.items.map((item, i) => (
          <div class={`relative flex items-start mb-12 last:mb-0 ${i % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
            <!-- Dot -->
            <div class="absolute left-4 md:left-1/2 w-4 h-4 rounded-full border-4 border-white shadow -translate-x-1/2 z-10" class:list={[timelineColors[i]]} aria-hidden="true"></div>

            <!-- Content card -->
            <div class={`ml-12 md:ml-0 md:w-[calc(50%-2rem)] ${i % 2 === 0 ? 'md:pr-8 md:text-right' : 'md:pl-8 md:text-left md:ml-auto'}`}>
              <div class="card p-6">
                <span class="badge bg-gold-50 text-gold-dark text-xs mb-2">{item.year}</span>
                <h3 class="font-heading text-lg font-bold text-charcoal mt-2">{item.title}</h3>
                <p class="font-body text-sm text-charcoal-light mt-2 leading-relaxed">{item.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Future HQ image -->
      <div class="mt-16 max-w-2xl mx-auto rounded-2xl overflow-hidden shadow-lg">
        <Image
          src={photoNewHQ}
          alt={lang === 'en' ? 'Artistic impression of the new Dynapharm International Headquarters' : 'Impression artistique du nouveau si\u00e8ge international Dynapharm'}
          class="w-full h-auto object-cover"
          widths={[400, 700]}
          sizes="(min-width: 768px) 672px, 100vw"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       LEADERSHIP — Key people
       ═══════════════════════════════════════════ -->
  <section class="section-padding bg-cream">
    <div class="section-container">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge bg-green-50 text-green mb-4">{c.leadership.sectionTag}</span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-charcoal">
          {c.leadership.heading}
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {c.leadership.members.map((member, i) => (
          <div class="card overflow-hidden group">
            <div class="aspect-[4/5] overflow-hidden bg-grey-light/30">
              <Image
                src={leadershipPhotos[i]}
                alt={member.name}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                widths={[300, 450]}
                sizes="(min-width: 768px) 33vw, 100vw"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h3 class="font-heading text-xl font-bold text-charcoal">{member.name}</h3>
              <p class="font-accent text-sm text-dynared font-medium mt-1">{member.title}</p>
              <p class="font-body text-sm text-charcoal-light mt-3 leading-relaxed">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       AWARDS & ACHIEVEMENTS
       ═══════════════════════════════════════════ -->
  <section class="section-padding bg-white">
    <div class="section-container">
      <div class="text-center max-w-3xl mx-auto mb-14">
        <span class="badge bg-gold-50 text-gold-dark mb-4">{c.awards.sectionTag}</span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-charcoal">
          {c.awards.heading}
        </h2>
        <p class="mt-4 text-lg text-charcoal-light font-body">{c.awards.description}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <Image
            src={photoAwards}
            alt={c.awards.altAwards}
            class="w-full h-auto object-cover"
            widths={[400, 600]}
            sizes="(min-width: 768px) 48vw, 100vw"
            loading="lazy"
          />
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <Image
            src={photoRecords}
            alt={c.awards.altRecords}
            class="w-full h-auto object-cover"
            widths={[400, 600]}
            sizes="(min-width: 768px) 48vw, 100vw"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FINAL CTA — Join the family
       ═══════════════════════════════════════════ -->
  <section class="relative bg-gradient-to-r from-green-dark via-green to-green-light py-20 md:py-28 overflow-hidden">
    <div class="absolute inset-0 grain-overlay opacity-50" aria-hidden="true"></div>

    <div class="section-container relative z-10 text-center">
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4">
        {c.cta.heading}
      </h2>
      <p class="text-lg text-green-100 font-body max-w-2xl mx-auto mb-10">
        {c.cta.subtitle}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`/${lang}/contact`} class="btn-primary bg-white text-green hover:bg-cream hover:text-green-dark text-base px-8 py-4 font-bold">
          {c.cta.ctaPrimary}
        </a>
        <a href={`/${lang}/products`} class="btn-secondary border-white text-white hover:bg-white hover:text-green text-base px-8 py-4">
          {c.cta.ctaSecondary}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

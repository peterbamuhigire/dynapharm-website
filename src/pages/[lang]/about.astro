---
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import { SUPPORTED_LANGS } from '@utils/i18n';
import type { Lang } from '@utils/i18n';
import BaseLayout from '@layouts/BaseLayout.astro';

// Hero image
import heroAbout from '@assets/images/about/DISTRIBUTORS-06.jpg';

// Origins photos
import photoOiHoChooi from '@assets/images/gallery/Oi-Ho-Chooi-Quote.jpg';
import photoHeadquarters from '@assets/images/gallery/REAL-PIC-DYNAPHARM-INTERNATIONAL-HEADQUARTERS.jpg';

// Africa chapter photos
import photoEsther from '@assets/images/gallery/ESTHER-AMPUMUZA.jpg';
import photoEstherOi from '@assets/images/gallery/ESTHER_AMPUMUZA-AND-OI_HO_CHOOI.jpg';

// Leadership photos
import photoFounder from '@assets/images/gallery/Oi-Ho-Chooi.jpg';
import photoJustus from '@assets/images/gallery/REAL-PIC-FOUNDER-JUSTUS-MUHANGI-AFRICA-TOP-DISTRIBUTOR.jpeg';

// Awards photos
import photoAwards from '@assets/images/gallery/DYNAPHARM-AWARDS-CERTIFICATES.jpg';
import photoRecords from '@assets/images/gallery/records-of-acievement.jpg';

// Future
import photoNewHQ from '@assets/images/gallery/ARTISTIC-IMPRESSION-NEW-HEADQUARTERS.jpg';

export const getStaticPaths = (() => {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: Lang };


<BaseLayout title={t.title} description={t.description} lang={lang}>

  <!-- Hero / Page Header -->
  <section class="relative overflow-hidden bg-green-dark text-white">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt=""
        class="w-full h-full object-cover opacity-20"
        widths={[640, 1024, 1600]}
        sizes="100vw"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-green-800/80 via-green-900/60 to-green-900"></div>
    </div>
    <div class="relative section-container section-padding text-center">
      <span class="inline-block font-accent text-sm font-medium uppercase tracking-widest text-green-300 mb-4">
        {lang === 'en' ? 'Natural Health Solutions' : 'Solutions de sant\u00E9 naturelles'}
      </span>
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
        {t.heading}
      </h1>
      <p class="text-lg md:text-xl text-green-100/80 max-w-3xl mx-auto font-body leading-relaxed mb-6">
        {t.subtitle}
      </p>
      <!-- Inline disclaimer -->
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-5 py-2.5 border border-white/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-300 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
        <span class="text-sm text-green-100 font-accent">{t.disclaimer}</span>
      </div>
    </div>
  </section>

  <!-- Wellness Categories Overview Grid -->
  <section class="section-padding bg-cream">
    <div class="section-container">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-block font-accent text-sm font-medium uppercase tracking-widest text-green mb-3">
          {lang === 'en' ? '11 Categories' : '11 Cat\u00E9gories'}
        </span>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold text-charcoal mb-4">{t.categoriesHeading}</h2>
        <p class="text-charcoal-light font-body text-lg max-w-2xl mx-auto">{t.categoriesSubtitle}</p>
      </div>

      <!-- Categories Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        {wellnessCategories.map((cat) => (
          <a
            href={`#${cat.id}`}
            class="group card p-5 md:p-6 text-center hover:border-green-200 transition-all duration-300"
          >
            <div class="w-14 h-14 rounded-xl bg-green-50 text-green mx-auto mb-4 flex items-center justify-center group-hover:bg-green group-hover:text-white transition-all duration-300">
              <span set:html={categoryIcons[cat.icon]} />
            </div>
            <h3 class="font-heading text-sm md:text-base font-semibold text-charcoal mb-2 group-hover:text-green transition-colors duration-200 leading-snug">
              {cat.name[lang]}
            </h3>
            <span class="font-accent text-xs text-grey">
              {cat.productCount} {t.relatedProducts.toLowerCase()}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Category Detail Sections (Accordion) -->
  <section
    class="section-padding bg-white"
    x-data="{ openSection: null, toggleSection(id) { this.openSection = this.openSection === id ? null : id; } }"
  >
    <div class="section-container max-w-4xl">
      <div class="flex items-center justify-between mb-8 md:mb-12">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-charcoal">
          {lang === 'en' ? 'Explore Each Category' : 'Explorer chaque cat\u00E9gorie'}
        </h2>
        <div class="flex gap-2">
          <button
            type="button"
            class="font-accent text-xs font-medium text-green hover:text-green-dark transition-colors px-3 py-1.5 rounded-full border border-green-200 hover:bg-green-50"
            x-on:click="openSection = 'all'"
          >
            {t.expandAll}
          </button>
          <button
            type="button"
            class="font-accent text-xs font-medium text-grey hover:text-charcoal transition-colors px-3 py-1.5 rounded-full border border-grey-light hover:bg-cream"
            x-on:click="openSection = null"
          >
            {t.collapseAll}
          </button>
        </div>
      </div>

      <div class="space-y-3">
        {wellnessCategories.map((cat) => (
          <div
            id={cat.id}
            class="border border-grey-light/50 rounded-xl overflow-hidden transition-all duration-200 scroll-mt-24"
            x-bind:class={`(openSection === '${cat.id}' || openSection === 'all') ? 'bg-white shadow-md border-green-200' : 'bg-cream-dark/30 hover:bg-cream-dark/50'`}
          >
            <!-- Accordion Header -->
            <button
              type="button"
              class="w-full flex items-center gap-4 p-5 md:p-6 text-left focus:outline-2 focus:outline-green focus:outline-offset-2"
              x-on:click={`toggleSection('${cat.id}')`}
              x-bind:aria-expanded={`(openSection === '${cat.id}' || openSection === 'all').toString()`}
              aria-controls={`panel-${cat.id}`}
            >
              <div class="w-12 h-12 rounded-xl bg-green-50 text-green flex items-center justify-center flex-shrink-0 transition-all duration-200"
                x-bind:class={`(openSection === '${cat.id}' || openSection === 'all') ? 'bg-green text-white' : 'bg-green-50 text-green'`}
              >
                <span set:html={categoryIcons[cat.icon]} />
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-heading text-lg md:text-xl font-bold text-charcoal">
                  {cat.name[lang]}
                </h3>
                <span class="font-accent text-xs text-grey">
                  {cat.productCount} {t.relatedProducts.toLowerCase()}
                </span>
              </div>
              <!-- Chevron -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-5 h-5 text-grey flex-shrink-0 transition-transform duration-200"
                x-bind:class={`(openSection === '${cat.id}' || openSection === 'all') ? 'rotate-180' : ''`}
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>

            <!-- Accordion Panel -->
            <div
              id={`panel-${cat.id}`}
              x-show={`openSection === '${cat.id}' || openSection === 'all'`}
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0 -translate-y-2"
              x-transition:enter-end="opacity-100 translate-y-0"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100"
              x-transition:leave-end="opacity-0"
              x-cloak
              role="region"
              aria-labelledby={`heading-${cat.id}`}
            >
              <div class="px-5 md:px-6 pb-6 pt-0">
                <div class="border-t border-grey-light/40 pt-5">
                  <!-- Description -->
                  <p class="text-charcoal-light font-body leading-relaxed mb-6">
                    {cat.description[lang]}
                  </p>

                  <!-- Related Products -->
                  <h4 class="font-heading text-sm font-semibold uppercase tracking-wider text-green mb-3 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
                    {t.relatedProducts}
                  </h4>
                  <ul class="space-y-2">
                    {cat.products.map((product) => (
                      <li class="flex items-center gap-3">
                        <div class="w-1.5 h-1.5 rounded-full bg-green flex-shrink-0"></div>
                        <span class="font-body text-sm text-charcoal">{product[lang]}</span>
                      </li>
                    ))}
                  </ul>

                  <!-- Link to products page -->
                  <a
                    href={`/${lang}/products`}
                    class="inline-flex items-center gap-1.5 mt-5 font-accent text-sm font-medium text-green hover:text-green-dark transition-colors"
                  >
                    {t.viewProduct}
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Medical Disclaimer -->
  <section class="section-padding bg-green-50 border-y border-green-100">
    <div class="section-container max-w-3xl">
      <div class="flex gap-4 md:gap-6">
        <div class="flex-shrink-0 w-12 h-12 rounded-full bg-green-100 text-green flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
        </div>
        <div>
          <h2 class="font-heading text-xl md:text-2xl font-bold text-charcoal mb-3">{t.disclaimerTitle}</h2>
          <p class="font-body text-charcoal-light leading-relaxed">
            {t.fullDisclaimer}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-gradient-to-br from-dynared to-dynared-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 grain-overlay opacity-20"></div>
    <!-- Decorative elements -->
    <div class="absolute -top-20 -right-20 w-56 h-56 rounded-full bg-white/5" aria-hidden="true"></div>
    <div class="absolute -bottom-12 -left-12 w-40 h-40 rounded-full bg-white/5" aria-hidden="true"></div>

    <div class="relative section-container text-center">
      <h2 class="font-heading text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{t.ctaTitle}</h2>
      <p class="text-white/80 font-body text-lg max-w-2xl mx-auto mb-8">{t.ctaText}</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={`/${lang}/contact`} class="inline-flex items-center justify-center px-8 py-4 bg-white text-dynared font-heading font-semibold rounded-lg hover:bg-cream hover:shadow-xl transition-all duration-300 text-lg gap-2">
          {t.ctaButton}
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href={`/${lang}/products`} class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-heading font-semibold rounded-lg hover:bg-white/10 transition-all duration-300 text-lg">
          {t.productsLink}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>

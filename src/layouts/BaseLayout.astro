---
import { getLocalizedPath, SUPPORTED_LANGS, t } from '@utils/i18n';
import type { Lang } from '@utils/i18n';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import '@styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  ogImage?: string;
  keywords?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  lang = 'en' as Lang,
  ogImage,
  keywords,
  structuredData,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site?.href || 'https://dynapharmafrica.com';
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : `${siteUrl}assets/images/branding/Logo-Full-Color.png`;

const localeMap: Record<string, string> = {
  en: 'en_GB',
  fr: 'fr_FR',
};

// Organization schema — site-wide
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Dynapharm Africa',
  url: siteUrl,
  logo: `${siteUrl}assets/images/branding/Logo-Full-Color.png`,
  description: lang === 'fr'
    ? 'Entreprise internationale de santé et bien-être proposant plus de 90 produits naturels et une opportunité d\'affaires éprouvée dans plus de 40 pays en Afrique.'
    : 'International health and wellness company offering 90+ natural products and a proven business opportunity across 40+ countries in Africa and beyond.',
  email: 'info@dynapharmafrica.com',
  foundingDate: '1981',
  knowsLanguage: ['en', 'fr'],
  areaServed: [
    { '@type': 'Continent', name: 'Africa' },
    'Uganda', 'Kenya', 'Nigeria', 'Senegal', 'Ghana', 'Tanzania',
    'Cameroon', 'Gabon', 'Zambia', 'Mozambique', 'Lesotho',
    'Sierra Leone', 'Rwanda', 'Burundi', 'DR Congo', 'Republic of the Congo',
    "Côte d'Ivoire", 'Mali', 'Burkina Faso', 'Niger', 'Togo', 'Benin',
    'Guinea', 'Madagascar', 'Malawi', 'Zimbabwe', 'Botswana',
    'Namibia', 'South Africa', 'Ethiopia', 'Sudan', 'South Sudan',
    'Angola', 'Eswatini', 'Liberia', 'Gambia', 'Chad',
  ],
  sameAs: [],
};

// BreadcrumbList schema for inner pages
const pathSegments = Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '').split('/');
const isHomePage = pathSegments.length <= 1 || (pathSegments.length === 2 && pathSegments[1] === '');
const breadcrumbSchema = !isHomePage ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: lang === 'fr' ? 'Accueil' : 'Home',
      item: `${siteUrl}${lang}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title.split('—')[0].split('|')[0].trim(),
      item: canonicalUrl.href,
    },
  ],
} : null;

// Collect all schemas
const allSchemas: Record<string, unknown>[] = [organizationSchema];
if (breadcrumbSchema) allSchemas.push(breadcrumbSchema);
if (structuredData) {
  if (Array.isArray(structuredData)) {
    allSchemas.push(...structuredData);
  } else {
    allSchemas.push(structuredData);
  }
}
---

<!DOCTYPE html>
<html lang={lang} dir="ltr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}

    <!-- Geo targeting — Africa -->
    <meta name="geo.region" content="002" />
    <meta name="geo.placename" content="Africa" />
    <meta name="content-language" content={lang} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- Hreflang alternates -->
    {SUPPORTED_LANGS.map((l) => (
      <link
        rel="alternate"
        hreflang={l}
        href={new URL(getLocalizedPath(Astro.url.pathname, l), Astro.site).href}
      />
    ))}
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(getLocalizedPath(Astro.url.pathname, 'en'), Astro.site).href}
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Dynapharm Africa" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:locale" content={localeMap[lang] || 'en_GB'} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload critical fonts -->
    <link rel="preconnect" href="/" crossorigin />

    <!-- Structured Data -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col bg-cream text-charcoal font-body antialiased">
    <!-- Skip to content (accessibility) -->
    <a href="#main-content" class="skip-to-content">
      {lang === 'en' ? 'Skip to content' : 'Aller au contenu'}
    </a>

    <Header lang={lang} />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer lang={lang} />

    <!-- Back to top button -->
    <button
      type="button"
      class="fixed bottom-6 right-6 z-40 w-11 h-11 rounded-full bg-dynared text-white shadow-lg hover:bg-dynared-dark hover:shadow-xl transition-all duration-300 flex items-center justify-center focus:outline-2 focus:outline-dynared focus:outline-offset-2"
      x-data="{ visible: false }"
      x-init="window.addEventListener('scroll', () => { visible = window.scrollY > 400 })"
      x-show="visible"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 scale-90"
      x-transition:enter-end="opacity-100 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 scale-100"
      x-transition:leave-end="opacity-0 scale-90"
      x-cloak
      x-on:click="window.scrollTo({ top: 0, behavior: 'smooth' })"
      aria-label={t(lang, 'common', 'backToTop')}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
      </svg>
    </button>

    <style>
      [x-cloak] {
        display: none !important;
      }
    </style>
  </body>
</html>

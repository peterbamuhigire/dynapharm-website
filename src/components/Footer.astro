---
import { Image } from 'astro:assets';
import { tSection, t, getNavItems } from '@utils/i18n';
import type { Lang } from '@utils/i18n';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import logoDark from '@assets/images/branding/Logo-Dark-Mode.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const footer = tSection(lang, 'footer');
const nav = tSection(lang, 'nav');

const footerNavItems = [
  { label: nav.products, href: `/${lang}/products` },
  { label: nav.business, href: `/${lang}/business-opportunity` },
  { label: nav.wellness, href: `/${lang}/wellness-guide` },
  { label: nav.about, href: `/${lang}/about` },
  { label: nav.contact, href: `/${lang}/contact` },
  { label: footer.faq, href: `/${lang}/faq` },
];
---

<footer class="bg-charcoal text-cream" role="contentinfo">
  <div class="section-container">
    <!-- Main Footer Content -->
    <div class="py-12 md:py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Column 1: Logo + Tagline -->
      <div class="lg:col-span-1">
        <a href={`/${lang}`} class="inline-block mb-4" aria-label="Dynapharm Africa">
          <Image
            src={logoDark}
            alt="Dynapharm Africa"
            class="h-10 w-auto"
            widths={[96, 144]}
            sizes="96px"
            loading="lazy"
          />
        </a>
        <p class="font-body text-sm text-grey-light leading-relaxed mb-6">
          {footer.tagline}
        </p>
        <LanguageSwitcher lang={lang} />
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-gold mb-4">
          {lang === 'en' ? 'Quick Links' : 'Liens Rapides'}
        </h3>
        <ul class="space-y-2.5" role="list">
          {footerNavItems.slice(0, 3).map((item) => (
            <li>
              <a
                href={item.href}
                class="font-accent text-sm text-grey-light hover:text-white transition-colors duration-200"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Company -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-gold mb-4">
          {lang === 'en' ? 'Company' : 'Entreprise'}
        </h3>
        <ul class="space-y-2.5" role="list">
          {footerNavItems.slice(3).map((item) => (
            <li>
              <a
                href={item.href}
                class="font-accent text-sm text-grey-light hover:text-white transition-colors duration-200"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-gold mb-4">
          {lang === 'en' ? 'Get in Touch' : 'Nous Contacter'}
        </h3>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href={`mailto:${footer.email}`}
              class="font-accent text-sm text-grey-light hover:text-white transition-colors duration-200 inline-flex items-center gap-2"
            >
              <!-- Email icon -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {footer.email}
            </a>
          </li>
          <li>
            <p class="font-accent text-sm text-grey-light inline-flex items-start gap-2">
              <!-- Globe icon -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 text-gold mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
              {footer.countries}
            </p>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-charcoal-light py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="font-accent text-xs text-grey text-center md:text-left">
          {footer.copyright}
        </p>
        <p class="font-accent text-xs text-grey text-center md:text-right italic max-w-lg">
          {footer.disclaimer}
        </p>
      </div>
      <div class="mt-4 text-center">
        <p class="font-accent text-xs text-grey">
          {lang === 'en' ? 'Built by' : 'Réalisé par'}{' '}
          <a
            href="https://techguypeter.com"
            target="_blank"
            rel="noopener"
            class="text-grey-light hover:text-white transition-colors duration-200 underline underline-offset-2"
            title="TechGuy Peter — Web Developer & Technology Consultant"
          >TechGuy Peter</a>
          {' & '}
          <a
            href="https://chwezi.co.za"
            target="_blank"
            rel="noopener"
            class="text-grey-light hover:text-white transition-colors duration-200 underline underline-offset-2"
            title="Chwezi Core Systems — Software Development & IT Solutions"
          >Chwezi Core Systems</a>
        </p>
      </div>
    </div>
  </div>
</footer>

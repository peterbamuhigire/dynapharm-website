---
import { Image } from 'astro:assets';
import { getNavItems, getCtaLabel, t } from '@utils/i18n';
import type { Lang } from '@utils/i18n';
import LanguageSwitcher from '@components/LanguageSwitcher.astro';
import logo from '@assets/images/branding/Logo-Full-Color.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const navItems = getNavItems(lang);
const ctaLabel = getCtaLabel(lang);
const menuOpenLabel = t(lang, 'common', 'menuOpen');
const menuCloseLabel = t(lang, 'common', 'menuClose');
const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-grey-light/40 transition-shadow duration-300"
  x-data="{ open: false }"
  x-on:keydown.escape.window="open = false"
>
  <div class="section-container">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href={`/${lang}`} class="flex-shrink-0" aria-label="Dynapharm Africa">
        <Image
          src={logo}
          alt="Dynapharm Africa"
          class="h-10 md:h-12 w-auto"
          widths={[96, 144]}
          sizes="(min-width: 768px) 144px, 96px"
          loading="eager"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || currentPath === item.href + '/';
          return (
            <a
              href={item.href}
              class:list={[
                'font-accent text-sm font-medium px-3 py-2 rounded-lg transition-colors duration-200',
                isActive
                  ? 'text-dynared bg-dynared-50'
                  : 'text-charcoal hover:text-dynared hover:bg-dynared-50/50',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Desktop Right Section: Language Switcher + CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <LanguageSwitcher lang={lang} />
        <a href={`/${lang}/contact`} class="btn-primary text-sm">
          {ctaLabel}
        </a>
      </div>

      <!-- Mobile Hamburger Button -->
      <button
        type="button"
        class="lg:hidden flex items-center justify-center w-11 h-11 rounded-lg text-charcoal hover:bg-dynared-50 transition-colors duration-200 focus:outline-2 focus:outline-dynared focus:outline-offset-2"
        x-on:click="open = !open"
        x-bind:aria-expanded="open.toString()"
        x-bind:aria-label="open ? `${menuCloseLabel}` : `${menuOpenLabel}`"
        aria-controls="mobile-menu"
      >
        <!-- Hamburger icon -->
        <svg
          x-show="!open"
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon -->
        <svg
          x-show="open"
          x-cloak
          xmlns="http://www.w3.org/2000/svg"
          class="w-6 h-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 top-16 z-40"
    x-show="open"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100"
    x-transition:leave-end="opacity-0"
    x-cloak
  >
    <!-- Backdrop -->
    <div
      class="absolute inset-0 bg-charcoal/60 backdrop-blur-sm"
      x-on:click="open = false"
      aria-hidden="true"
    ></div>

    <!-- Menu panel -->
    <nav
      class="relative bg-white h-full overflow-y-auto shadow-xl"
      x-show="open"
      x-transition:enter="transition ease-out duration-200 delay-75"
      x-transition:enter-start="translate-y-[-1rem] opacity-0"
      x-transition:enter-end="translate-y-0 opacity-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="translate-y-0 opacity-100"
      x-transition:leave-end="translate-y-[-1rem] opacity-0"
      aria-label="Mobile navigation"
    >
      <div class="px-4 py-6 space-y-1">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || currentPath === item.href + '/';
          return (
            <a
              href={item.href}
              class:list={[
                'block font-accent text-base font-medium px-4 py-3 rounded-lg transition-colors duration-200',
                isActive
                  ? 'text-dynared bg-dynared-50'
                  : 'text-charcoal hover:text-dynared hover:bg-dynared-50/50',
              ]}
              aria-current={isActive ? 'page' : undefined}
              x-on:click="open = false"
            >
              {item.label}
            </a>
          );
        })}

        <!-- Divider -->
        <div class="border-t border-grey-light/60 my-4" role="separator"></div>

        <!-- Language Switcher -->
        <div class="px-4 py-2">
          <LanguageSwitcher lang={lang} />
        </div>

        <!-- CTA Button -->
        <div class="px-4 pt-2">
          <a
            href={`/${lang}/contact`}
            class="btn-primary w-full text-center text-base"
            x-on:click="open = false"
          >
            {ctaLabel}
          </a>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
